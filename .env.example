# Qore Platform Environment Variables
# Copy this file to .env.local and fill in your API keys

# ============================================
# FRONTEND (Vite) - prefix with VITE_
# ============================================

# Google Gemini API Key (for AI Copilot and Concept Explorer)
# Get your key at: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=

# YouTube Data API Key (for video search in Learning Center)
# Get from: https://console.cloud.google.com/apis/credentials
# Enable: YouTube Data API v3
VITE_YOUTUBE_API_KEY=

# ============================================
# BACKEND (Python/FastAPI) - create backend/.env
# ============================================

# OAuth Configuration
# Google OAuth - https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth - https://github.com/settings/developers
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret

# JWT Secret (generate a random string)
# SECRET_KEY=your_random_secret_key_for_jwt

# Database
# DATABASE_URL=sqlite:///./qore.db
