# ==============================================
# Qore Platform - Backend Environment Variables
# ==============================================
# Copy this file to .env and fill in your values
# ==============================================

# Server Configuration
SECRET_KEY=your-super-secret-key-change-in-production
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
DEBUG=true

# Database (SQLite by default, change for production)
DATABASE_URL=sqlite+aiosqlite:///./qore.db

# ================================================
# GOOGLE OAUTH SETUP
# ================================================
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a new OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URI: http://localhost:8000/auth/google/callback
# 4. Copy Client ID and Client Secret below
# ================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ================================================
# GITHUB OAUTH SETUP
# ================================================
# 1. Go to https://github.com/settings/developers
# 2. Create a new OAuth App
# 3. Set Homepage URL: http://localhost:5173
# 4. Set Authorization callback URL: http://localhost:8000/auth/github/callback
# 5. Copy Client ID and generate a Client Secret
# ================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AI Integration (Optional - for enhanced AI features)
# Gemini - Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenAI (Optional alternative)
OPENAI_API_KEY=

# JWT Settings
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
